# Copy to .env and fill locally. Never commit .env.
FEATHERLESS_API_KEY=
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.featherless.ai/v1
OPENAI_MODEL=openai/gpt-oss-20b
PROOFGATE_MIRROR_DB=

# Band agent credentials (one per role)
BAND_INTAKE_AGENT_ID=
BAND_INTAKE_API_KEY=
BAND_PLANNER_AGENT_ID=
BAND_PLANNER_API_KEY=
BAND_RESOLUTION_AGENT_ID=
BAND_RESOLUTION_API_KEY=
# Compatibility aliases: BAND_ENGINEER_AGENT_ID / BAND_ENGINEER_API_KEY
BAND_ISSUE_ISOLATOR_AGENT_ID=
BAND_ISSUE_ISOLATOR_API_KEY=
BAND_FINALIZING_AGENT_ID=
BAND_FINALIZING_API_KEY=
# Compatibility aliases: BAND_REVIEWER_AGENT_ID / BAND_REVIEWER_API_KEY

# ProofGate internal chat configuration
PROOFGATE_CHAT_MODE=local
PROOFGATE_HOST=127.0.0.1
PROOFGATE_PORT=8080
PROOFGATE_AUTOSTART_AGENTS=true
PROOFGATE_AGENT_START_TIMEOUT_SECONDS=20
PROOFGATE_AGENT_RESTART_LIMIT=1

# Band Human API (for sending messages as human)
BAND_HUMAN_API_KEY=
BAND_ROOM_ID=
BAND_API_BASE_URL=https://app.band.ai/api/v1

# Band Intake participant identity (UUID in the room)
BAND_INTAKE_HANDLE=itz1508/intake
BAND_INTAKE_PARTICIPANT_ID=
